PORT=4002
# Point to the payments service (same as main backend)
PAYMENTS_SERVICE_URL=http://localhost:4001

# CORS for client traffic (dev + prod). Include your Flutter web origins and production domain.
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5000,https://dvenueapp.vercel.app

# Firebase public config (same as main backend)
FIREBASE_API_KEY=AIzaSyDKkDFGQpbDVpXKXnkvh80_dVC5Fogw9X8
FIREBASE_AUTH_DOMAIN=inventory-management-ce97e.firebaseapp.com
FIREBASE_PROJECT_ID=inventory-management-ce97e
FIREBASE_STORAGE_BUCKET=inventory-management-ce97e.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=101037199273
FIREBASE_APP_ID=1:101037199273:web:98e8c4329e5fd9b411feb8

# Firebase Admin (service account) - same credentials as main backend for token verification + Firestore.
# For security/isolation: in production consider a more restricted SA if possible, but Admin SDK is required for ID token verify + user profile writes.
# Local dev: place the service account JSON in ../backend/ (or set GOOGLE_APPLICATION_CREDENTIALS)
GOOGLE_APPLICATION_CREDENTIALS=../backend/inventory-management-ce97e-firebase-adminsdk-r6egv-3376080a19.json

# Feature flags (client backend always behaves as client-only)
ENABLE_OTP_VERIFY=false
ENABLE_GOOGLE_SIGNIN=false

# Supabase (if client backend ever needs direct payments table reads - currently proxied)
SUPABASE_URL=https://vhqeqwqdaxdhmomghbwd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_publishable_ZbzJAx5034olHkfGgRCxWQ_x-MUJIIh

# Rate limits (stricter for public client surface recommended)
AUTH_RATE_LIMIT=60
WRITE_RATE_LIMIT=60

# Dev OTP (if re-enabling OTP in client flows)
AUTH_DEV_OTP=
AUTH_RETURN_OTP=false

# First admin email (promoted on profile create - used if staff uses client backend, but admin ops should go to main backend)
DEFAULT_ADMIN_EMAIL=